# Rendered by nginx's entrypoint (envsubst over ${PORT}) into
# /etc/nginx/conf.d/default.conf at container start — Railway assigns the
# port per deployment, so it can't be baked into the image.

server {
    listen       ${PORT};
    listen       [::]:${PORT};
    server_name  _;

    root  /usr/share/nginx/html;
    index index.html;

    # Phaser bundles compress well; ~1.5 MB down to a few hundred KB.
    gzip             on;
    gzip_vary        on;
    gzip_min_length  1024;
    gzip_types       text/plain text/css application/javascript application/json
                     image/svg+xml application/wasm;

    # Railway's healthcheck: cheap and independent of the built files.
    location = /healthz {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # Bundle filenames carry a content hash, so they can be cached forever.
    location /assets/ {
        # No `expires` here — it would emit a second, weaker Cache-Control
        # header alongside this one.
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # index.html must not be cached, or players keep getting the old build.
    location = /index.html {
        add_header Cache-Control "public, max-age=0, must-revalidate";
    }

    # Single page app: anything not found still serves the game.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
